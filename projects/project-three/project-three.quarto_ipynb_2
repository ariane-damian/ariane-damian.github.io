        "#| code-fold: show\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# ── Counts taken directly from official dataset──────────────────────────\n",
        "counts = [4101, 18540]          # [Not Recommended (0), Recommended (1)]\n",
        "bar_labels   = ['Not Recommended (0)', 'Recommended (1)']\n",
        "bar_colors   = ['#E8735A', '#6DBF8A']\n",
        "\n",
        "# ── Plot ─────────────────────────────────────────────────────────────────────\n",
        "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
